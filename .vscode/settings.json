{
    // Intérprete por defecto del entorno virtual
    "python.defaultInterpreterPath": ".venv\\Scripts\\python.exe",

    // Usar PowerShell como terminal por defecto
    "terminal.integrated.defaultProfile.windows": "PowerShell",

    // Activación automática cuando la terminal la abre la extensión de Python
    "python.terminal.activateEnvironment": true,

    // Perfil personalizado de PowerShell con activación forzada del venv
    "terminal.integrated.profiles.windows": {
        "PowerShell": {
            "source": "PowerShell",
            "args": [
                "-NoExit",
                "-Command",
                "if (Test-Path .\\.venv\\Scripts\\Activate.ps1) { & .\\.venv\\Scripts\\Activate.ps1 }"
            ]
        }
    },

    // Opcional: asegura que el entorno se detecte correctamente en el workspace
    "python.venvPath": ".",

    // Mejora la detección de entornos en proyectos
    "python.envFile": "${workspaceFolder}\\.env"
}